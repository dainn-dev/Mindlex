# Copy to .env and fill in. docker compose will pick these up automatically.

# --- NuGet (only if DainnStripe / DainnUser are on a private feed) -----------
# Example for Azure DevOps Artifacts / GitHub Packages NuGet:
#   NUGET_FEED_URL=https://pkgs.dev.azure.com/<org>/_packaging/<feed>/nuget/v3/index.json
#   NUGET_USERNAME=anything
#   NUGET_PAT=<personal-access-token>
NUGET_FEED_URL=
NUGET_USERNAME=
NUGET_PAT=

# --- Secrets ----------------------------------------------------------------
# JWT secret must be >= 32 chars in production.
JWT_SECRET=dev-only-not-for-production-please-replace-32chars

# Stripe — DainnStripe lib validates these on boot, so they can't be blank.
# Defaults injected by compose are Stripe's public test placeholders which
# let the app start but won't process real payments. Override with your
# real test keys (sk_test_...) to actually exercise checkout flows.
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# --- Frontend ---------------------------------------------------------------
# Where the FE should send /api/... requests. Inside compose nginx proxies
# this to the backend service, so "/api" works out-of-the-box.
VITE_API_BASE_URL=/api

# --- Dev admin (seeded on first boot) --------------------------------------
# Login at http://localhost:3000/login with these credentials.
# Password must satisfy: >=8 chars, >=1 digit, >=1 uppercase,
# >=1 special char from @#!$%^&*
ADMIN_FULLNAME=Mindlex Dev Admin
ADMIN_EMAIL=admin@mindlex.local
ADMIN_PASSWORD=Admin123!

# --- Host port mapping (avoid collisions) ----------------------------------
# Change if 55432 is taken; e.g. POSTGRES_HOST_PORT=5433
POSTGRES_HOST_PORT=55432
