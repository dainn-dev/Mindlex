# Copy to .env and fill in. docker compose will pick these up automatically.

# --- NuGet (only if DainnStripe / DainnUser are on a private feed) -----------
# Example for Azure DevOps Artifacts / GitHub Packages NuGet:
#   NUGET_FEED_URL=https://pkgs.dev.azure.com/<org>/_packaging/<feed>/nuget/v3/index.json
#   NUGET_USERNAME=anything
#   NUGET_PAT=<personal-access-token>
NUGET_FEED_URL=
NUGET_USERNAME=
NUGET_PAT=

# --- Secrets ----------------------------------------------------------------
# JWT secret must be >= 32 chars in production.
JWT_SECRET=dev-only-not-for-production-please-replace-32chars

# Stripe (leave blank for dev — billing flows will fail but rest works)
STRIPE_SECRET=sk_test_REMOVED_use_env_file
STRIPE_WEBHOOK_SECRET=

# --- Frontend ---------------------------------------------------------------
# Where the FE should send /api/... requests. Inside compose nginx proxies
# this to the backend service, so "/api" works out-of-the-box.
VITE_API_BASE_URL=/api
BLUEBERRY_SENSEI_CLAUDE_WIZARD_TOKEN=github_pat_REMOVED_use_env_file